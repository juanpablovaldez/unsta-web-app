<div class="page-header">
  <h1>Edit Task</h1>
</div>

{{#if error}}
  <p class="error" role="alert">{{error}}</p>
{{/if}}

<form class="edit-form" action="/{{todo._id}}/update" method="POST">
  <div class="field">
    <label for="task-title">Title</label>
    <input
      type="text"
      id="task-title"
      name="title"
      value="{{todo.title}}"
      maxlength="200"
      required
      autofocus
      autocomplete="off"
    >
  </div>

  <label class="checkbox-row">
    <input type="checkbox" name="completed" {{#if todo.completed}}checked{{/if}}>
    Mark as completed
  </label>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/" class="btn btn-secondary">Cancel</a>
  </div>
</form>
