<h1>Edit Task</h1>

{{#if error}}
  <p class="error">{{error}}</p>
{{/if}}

<form class="edit-form" action="/{{todo._id}}/update" method="POST">
  <label>
    Title
    <input type="text" name="title" value="{{todo.title}}" maxlength="200" required autofocus>
  </label>

  <div class="checkbox-row">
    <input type="checkbox" name="completed" id="completed" {{#if todo.completed}}checked{{/if}}>
    <label for="completed">Mark as completed</label>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/" class="btn btn-secondary">Cancel</a>
  </div>
</form>
