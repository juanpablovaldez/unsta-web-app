<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>To-Do App</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: #f5f5f5;
      color: #222;
      padding: 2rem 1rem;
    }

    .container {
      max-width: 600px;
      margin: 0 auto;
    }

    h1 {
      font-size: 1.75rem;
      margin-bottom: 1.5rem;
    }

    .error {
      color: #c0392b;
      background: #fdecea;
      border: 1px solid #e74c3c;
      padding: 0.5rem 0.75rem;
      border-radius: 4px;
      margin-bottom: 1rem;
      font-size: 0.9rem;
    }

    form.create-form {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    form.create-form input[type="text"] {
      flex: 1;
      padding: 0.5rem 0.75rem;
      border: 1px solid #ccc;
      border-radius: 4px;
      font-size: 1rem;
    }

    button, .btn {
      padding: 0.5rem 1rem;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.9rem;
      text-decoration: none;
      display: inline-block;
    }

    .btn-primary { background: #3498db; color: #fff; }
    .btn-primary:hover { background: #2980b9; }
    .btn-danger { background: #e74c3c; color: #fff; }
    .btn-danger:hover { background: #c0392b; }
    .btn-secondary { background: #bdc3c7; color: #222; }
    .btn-secondary:hover { background: #95a5a6; }

    ul.todo-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    li.todo-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: #fff;
      padding: 0.6rem 0.75rem;
      border-radius: 4px;
      border: 1px solid #ddd;
    }

    li.todo-item .title {
      flex: 1;
      font-size: 1rem;
    }

    li.todo-item.completed .title {
      text-decoration: line-through;
      color: #999;
    }

    li.todo-item .actions {
      display: flex;
      gap: 0.4rem;
    }

    .edit-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      background: #fff;
      padding: 1.5rem;
      border-radius: 6px;
      border: 1px solid #ddd;
    }

    .edit-form label {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      font-size: 0.9rem;
      font-weight: 600;
    }

    .edit-form input[type="text"] {
      padding: 0.5rem 0.75rem;
      border: 1px solid #ccc;
      border-radius: 4px;
      font-size: 1rem;
    }

    .edit-form .checkbox-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.95rem;
    }

    .edit-form .form-actions {
      display: flex;
      gap: 0.5rem;
    }

    .empty-state {
      color: #999;
      font-style: italic;
      margin-top: 0.5rem;
    }
  </style>
</head>
<body>
  <div class="container">
    {{{body}}}
  </div>
</body>
</html>
