<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <title>Tasks</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #fafafa;
      --surface: #ffffff;
      --border: #e5e5e5;
      --text: #171717;
      --text-muted: #737373;
      --text-faint: #a3a3a3;
      --accent: #171717;
      --accent-focus-ring: rgba(23, 23, 23, 0.12);
      --danger: #ef4444;
      --danger-bg: #fef2f2;
      --danger-border: #fecaca;
      --radius: 8px;
      --shadow: 0 1px 2px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0a0a0a;
        --surface: #171717;
        --border: #262626;
        --text: #fafafa;
        --text-muted: #a3a3a3;
        --text-faint: #525252;
        --accent: #fafafa;
        --accent-focus-ring: rgba(250, 250, 250, 0.15);
        --danger-bg: #1c0a0a;
        --danger-border: #7f1d1d;
        --shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
      }
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      padding: 3.5rem 1.25rem;
      min-height: 100dvh;
      color-scheme: light dark;
    }

    .container {
      max-width: 540px;
      margin: 0 auto;
    }

    /* Utility */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* Page header */
    .page-header {
      margin-bottom: 2rem;
    }

    .page-header h1 {
      font-size: 1.375rem;
      font-weight: 600;
      letter-spacing: -0.025em;
      color: var(--text);
    }

    /* Error */
    .error {
      color: var(--danger);
      background: var(--danger-bg);
      border: 1px solid var(--danger-border);
      padding: 0.625rem 0.875rem;
      border-radius: var(--radius);
      margin-bottom: 1.25rem;
      font-size: 0.875rem;
    }

    /* Inputs */
    input[type="text"] {
      width: 100%;
      padding: 0.625rem 0.875rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      font-size: 0.9375rem;
      color: var(--text);
      background: var(--surface);
      box-shadow: var(--shadow);
      outline: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
      -webkit-appearance: none;
    }

    input[type="text"]:focus-visible {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-focus-ring);
    }

    input[type="text"]::placeholder {
      color: var(--text-faint);
    }

    /* Checkbox */
    input[type="checkbox"] {
      width: 1.0625rem;
      height: 1.0625rem;
      border-radius: 4px;
      cursor: pointer;
      accent-color: var(--accent);
      outline: none;
      flex-shrink: 0;
    }

    input[type="checkbox"]:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* Buttons */
    button, .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.375rem;
      padding: 0.625rem 1rem;
      min-height: 44px;
      border: 1px solid transparent;
      border-radius: var(--radius);
      cursor: pointer;
      font-size: 0.875rem;
      font-weight: 500;
      font-family: inherit;
      text-decoration: none;
      white-space: nowrap;
      outline: none;
      transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }

    button:focus-visible, .btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .btn-primary {
      background: var(--accent);
      color: var(--bg);
      border-color: var(--accent);
    }

    .btn-primary:hover {
      opacity: 0.85;
    }

    .btn-secondary {
      background: transparent;
      color: var(--text-muted);
      border-color: var(--border);
    }

    .btn-secondary:hover {
      background: var(--bg);
      color: var(--text);
    }

    .btn-danger {
      background: transparent;
      color: var(--text-faint);
      border-color: transparent;
    }

    .btn-danger:hover {
      background: var(--danger-bg);
      color: var(--danger);
      border-color: var(--danger-border);
    }

    /* Create form */
    .create-form {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .create-form input[type="text"] {
      flex: 1;
      width: auto;
    }

    /* Todo list */
    .todo-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.3125rem;
    }

    .todo-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--surface);
      padding: 0.8125rem 1rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      transition: border-color 0.15s ease;
    }

    .todo-item:hover {
      border-color: var(--text-faint);
    }

    .todo-item.completed {
      opacity: 0.55;
    }

    .todo-item .toggle-form {
      display: flex;
      align-items: center;
    }

    .todo-item .title {
      flex: 1;
      font-size: 0.9375rem;
      color: var(--text);
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .todo-item.completed .title {
      text-decoration: line-through;
      color: var(--text-muted);
    }

    .todo-item .actions {
      display: flex;
      gap: 0.25rem;
      align-items: center;
      flex-shrink: 0;
    }

    .todo-item .actions .btn {
      padding: 0.375rem 0.625rem;
      min-height: 36px;
      font-size: 0.8125rem;
    }

    /* Edit form */
    .edit-form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      background: var(--surface);
      padding: 1.75rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .edit-form .field {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    .edit-form .field label {
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--text-muted);
    }

    .edit-form .checkbox-row {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      font-size: 0.9375rem;
      color: var(--text);
      cursor: pointer;
    }

    .edit-form .form-actions {
      display: flex;
      gap: 0.5rem;
      padding-top: 0.25rem;
    }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 3.5rem 1rem;
    }

    .empty-state p {
      font-size: 0.9375rem;
      color: var(--text-muted);
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        transition-duration: 0.01ms !important;
        animation-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    {{{body}}}
  </div>
</body>
</html>
